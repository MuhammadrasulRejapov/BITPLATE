@startuml BitePlate_Core_System_Class_Diagram

skinparam classAttributeIconSize 0
skinparam classFontSize 10
skinparam packageStyle rectangle
skinparam packageBackgroundColor #F8F9FA
skinparam packageBorderColor #AAAAAA
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #444444
skinparam interfaceBackgroundColor #E8F4FD
skinparam interfaceBorderColor #2980B9
skinparam abstractClassBackgroundColor #FFF9E6
skinparam abstractClassBorderColor #E67E22
skinparam arrowColor #333333
skinparam stereotypeCBackgroundColor #D5E8D4
skinparam noteFontSize 9

' ═══════════════════════════════════════════════════════════════════════════
' ENUMS
' ═══════════════════════════════════════════════════════════════════════════

enum OrderStatus {
    Pending
    Preparing
    Ready
    Served
}

enum TableStatus {
    Free
    Reserved
    Occupied
    AwaitingBill
    Cleared
}

' ═══════════════════════════════════════════════════════════════════════════
' DOMAIN ENTITIES
' ═══════════════════════════════════════════════════════════════════════════

package "Domain.Entities" #EDF8FF {

    class User {
        +Id : int
        +Username : string
        +PasswordHash : string
        +Role : string
        +DisplayName : string
        +IsActive : bool
    }

    class Table {
        +Id : int
        +Number : int
        +Capacity : int
        +Status : TableStatus
        +CurrentGuests : int
        +OccupiedSince : string?
        +WaiterName : string?
        +ReservationTime : string?
        +GuestName : string?
    }

    class Order {
        +Id : string
        +TableNumber : int
        +Time : string
        +Status : OrderStatus
        +Waiter : string
    }

    class OrderItem {
        +MenuItemId : string
        +Name : string
        +Qty : int
        +Price : decimal
    }

    class OrderAddon {
        +Name : string
        +Price : decimal
    }

    class MenuItem {
        +Id : string
        +Name : string
        +Category : string
        +Price : decimal
        +Description : string
        +Image : string
        +Allergens : List<string>
    }

    class MenuAddon {
        +Id : string
        +Name : string
        +Price : decimal
    }

    class Reservation {
        +Id : string
        +GuestName : string
        +Phone : string
        +TableNumber : int
        +Guests : int
        +Time : DateTime
        +Status : string
        +Note : string
    }

    class HistoryEntry {
        +Id : string
        +TableNumber : int
        +Waiter : string
        +StaffId : string?
        +Total : decimal
        +Status : string
        +Timestamp : DateTime
        +PaymentMethod : string?
        +Items : List<string>
        +Discount : decimal
        +FreeDrinkValue : decimal
        +Tip : decimal
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' DATA LAYER
' ═══════════════════════════════════════════════════════════════════════════

package "Data" #FFF8E7 {

    class AppDbContext {
        +Tables : DbSet<Table>
        +Orders : DbSet<Order>
        +MenuItems : DbSet<MenuItem>
        +Reservations : DbSet<Reservation>
        +HistoryEntries : DbSet<HistoryEntry>
        +Users : DbSet<User>
        +OnModelCreating(builder) : void
    }

    class DbSeeder {
        +{static} SeedAsync(db : AppDbContext) : Task
        -{static} SeedMenu(db : AppDbContext) : Task
        -{static} SeedUsers(db : AppDbContext) : Task
        -{static} SeedTables(db : AppDbContext) : Task
        -{static} SeedReservations(db : AppDbContext) : Task
        +{static} BuildCombos() : IReadOnlyList<IMenuComponent>
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' PATTERN: COMMAND
' ═══════════════════════════════════════════════════════════════════════════

package "Patterns.Command" #EDFAED {

    interface ICommand {
        +Execute() : void
        +Undo() : void
        +Description : string
    }

    class PrepareOrderCommand {
        -_db : AppDbContext
        -_orderId : string
        -_previousStatus : OrderStatus
        +Description : string
        +Execute() : void
        +Undo() : void
    }

    class CancelOrderCommand {
        -_db : AppDbContext
        -_orderId : string
        -_cancelled : Order?
        +Description : string
        +Execute() : void
        +Undo() : void
    }

    class UpdateOrderStatusCommand {
        -_db : AppDbContext
        -_orderId : string
        -_nextStatus : OrderStatus
        -_previousStatus : OrderStatus
        +Description : string
        +Execute() : void
        +Undo() : void
    }

    class KitchenCommandInvoker {
        -_history : Stack<ICommand>
        +CanUndo : bool
        +History : IReadOnlyCollection<string>
        +Execute(cmd : ICommand) : void
        +Undo() : string?
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' PATTERN: OBSERVER
' ═══════════════════════════════════════════════════════════════════════════

package "Patterns.Observer" #FFF0F5 {

    interface IOrderObserver {
        +ObserverId : string
        +OnOrderEvent(evt : OrderEvent) : void
    }

    class OrderEvent {
        +EventType : string
        +Order : Order
        +Extra : string?
    }

    class OrderEventBus {
        -_observers : List<IOrderObserver>
        -_pendingEvents : Queue<OrderEvent>
        -_lock : object
        +Subscribe(observer : IOrderObserver) : void
        +Unsubscribe(observerId : string) : void
        +Publish(eventType : string, order : Order, extra : string?) : void
        +DrainEvents() : IReadOnlyList<OrderEvent>
    }

    class KitchenObserver {
        +ObserverId : string = "kitchen-display"
        +OnOrderEvent(evt : OrderEvent) : void
    }

    class WaiterObserver {
        +ObserverId : string = "waiter-notification"
        +OnOrderEvent(evt : OrderEvent) : void
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' PATTERN: STRATEGY
' ═══════════════════════════════════════════════════════════════════════════

package "Patterns.Strategy" #F0F0FF {

    interface IPricingStrategy {
        +Name : string
        +DiscountRate : decimal
        +FreeDrinkValue : decimal
        +Apply(subtotal : decimal) : decimal
    }

    class StandardPricingStrategy {
        +Name : string = "standard"
        +DiscountRate : decimal = 0.00
        +FreeDrinkValue : decimal = 0
        +Apply(subtotal : decimal) : decimal
    }

    class HappyHourStrategy {
        +Name : string = "happyhour"
        +DiscountRate : decimal = 0.20
        +FreeDrinkValue : decimal = 0
        +Apply(subtotal : decimal) : decimal
    }

    class LoyaltyDiscountStrategy {
        +Name : string = "loyalty"
        +DiscountRate : decimal = 0.10
        +FreeDrinkValue : decimal = 15000
        +Apply(subtotal : decimal) : decimal
    }

    class GroupDiscountStrategy {
        +Name : string = "group"
        +DiscountRate : decimal = 0.15
        +FreeDrinkValue : decimal = 0
        +Apply(subtotal : decimal) : decimal
    }

    class PricingStrategyFactory {
        -{static} _strategies : Dictionary<string, IPricingStrategy>
        +{static} GetStrategy(name : string) : IPricingStrategy
        +{static} GetAll() : IEnumerable<object>
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' PATTERN: STATE
' ═══════════════════════════════════════════════════════════════════════════

package "Patterns.State" #FFF5E0 {

    interface ITableState {
        +StateName : string
        +SeatGuests(ctx : TableContext, guestCount : int, waiterName : string?) : void
        +Reserve(ctx : TableContext, guestName : string, time : string) : void
        +SubmitOrder(ctx : TableContext) : void
        +RequestBill(ctx : TableContext) : void
        +CloseBill(ctx : TableContext) : void
        +Clear(ctx : TableContext) : void
    }

    class TableContext {
        -_table : Table
        -_state : ITableState
        +TableContext(table : Table)
        +SeatGuests(guestCount : int, waiterName : string?) : void
        +Reserve(guestName : string, time : string) : void
        +SubmitOrder() : void
        +RequestBill() : void
        +CloseBill() : void
        +Clear() : void
        +TransitionTo(state : ITableState, status : TableStatus) : void
    }

    class FreeState {
        +StateName : string = "Free"
    }

    class ReservedState {
        +StateName : string = "Reserved"
    }

    class OccupiedState {
        +StateName : string = "Occupied"
    }

    class AwaitingBillState {
        +StateName : string = "AwaitingBill"
    }

    class ClearedState {
        +StateName : string = "Cleared"
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' PATTERN: SINGLETON
' ═══════════════════════════════════════════════════════════════════════════

package "Patterns.Singleton" #F5F5FF {

    class OrderHistoryLog <<Singleton>> {
        -{static} _instance : Lazy<OrderHistoryLog>
        -_entries : List<HistoryEntry>
        -_lock : object
        -OrderHistoryLog()
        +{static} Instance : OrderHistoryLog
        +Append(entry : HistoryEntry) : void
        +GetAll() : IReadOnlyList<HistoryEntry>
        +GetByTable(tableNumber : int) : IReadOnlyList<HistoryEntry>
        +GetMostFrequentItem() : string?
        +SeedBulk(entries : IEnumerable<HistoryEntry>) : void
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' PATTERN: ITERATOR
' ═══════════════════════════════════════════════════════════════════════════

package "Patterns.Iterator" #F0FFF5 {

    interface IHistoryIterator {
        +HasNext() : bool
        +Next() : HistoryEntry
        +Reset() : void
    }

    class FilteredHistoryIterator {
        -_source : IReadOnlyList<HistoryEntry>
        -_cursor : int
        +FilteredHistoryIterator(from : DateTime?, to : DateTime?)
        +HasNext() : bool
        +Next() : HistoryEntry
        +Reset() : void
        +ToList() : List<HistoryEntry>
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' PATTERN: DECORATOR
' ═══════════════════════════════════════════════════════════════════════════

package "Patterns.Decorator" #FFF0E0 {

    interface IMealComponent {
        +GetDescription() : string
        +GetPrice() : decimal
    }

    class BaseMealItem {
        -_name : string
        -_price : decimal
        +BaseMealItem(name : string, price : decimal)
        +GetDescription() : string
        +GetPrice() : decimal
    }

    class AddonDecorator {
        -_inner : IMealComponent
        -_addonName : string
        -_addonPrice : decimal
        +AddonDecorator(inner : IMealComponent, addonName : string, addonPrice : decimal)
        +GetDescription() : string
        +GetPrice() : decimal
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' PATTERN: FACADE
' ═══════════════════════════════════════════════════════════════════════════

package "Patterns.Facade" #F5FFFF {

    class BillingFacade {
        -{static} TaxRate : decimal = 0.12
        +ProcessPayment(order : Order, strategy : IPricingStrategy, tip : decimal, splitCount : int) : BillResult
        -{static} CalculateSubtotal(order : Order) : decimal
    }

    class BillResult <<record>> {
        +Subtotal : decimal
        +Discount : decimal
        +DiscountRate : decimal
        +FreeDrinkValue : decimal
        +Tax : decimal
        +Tip : decimal
        +Total : decimal
        +PerPerson : decimal
        +SplitCount : int
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' PATTERN: FACTORY
' ═══════════════════════════════════════════════════════════════════════════

package "Patterns.Factory" #F8EAFF {

    abstract class MealItemFactory {
        +{abstract} CreateMenuItem(id : string, name : string, category : string, price : decimal, description : string, image : string, allergens : List<string>, addons : List<MenuAddon>) : MenuItem
        #{static} BuildBase(id : string, name : string, category : string, price : decimal, description : string, image : string, allergens : List<string>, addons : List<MenuAddon>) : MenuItem
    }

    class StandardMealFactory {
        +CreateMenuItem(id : string, name : string, category : string, price : decimal, description : string, image : string, allergens : List<string>, addons : List<MenuAddon>) : MenuItem
    }

    class ComboMealFactory {
        +CreateMenuItem(id : string, name : string, category : string, price : decimal, description : string, image : string, allergens : List<string>, addons : List<MenuAddon>) : MenuItem
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' PATTERN: COMPOSITE
' ═══════════════════════════════════════════════════════════════════════════

package "Patterns.Composite" #EAFFF8 {

    interface IMenuComponent {
        +Id : string
        +Name : string
        +IsCombo : bool
        +GetPrice() : decimal
        +GetDescription() : string
        +Children : IReadOnlyList<IMenuComponent>
        +Add(component : IMenuComponent) : void
    }

    class SingleMenuItem {
        -_item : MenuItem
        +Id : string
        +Name : string
        +IsCombo : bool = false
        +GetPrice() : decimal
        +GetDescription() : string
        +Children : IReadOnlyList<IMenuComponent>
        +Add(component : IMenuComponent) : void
    }

    class ComboMealGroup {
        -_children : List<IMenuComponent>
        -_discountRate : decimal
        +Id : string
        +Name : string
        +IsCombo : bool = true
        +GetPrice() : decimal
        +GetDescription() : string
        +Children : IReadOnlyList<IMenuComponent>
        +Add(component : IMenuComponent) : void
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' SERVICES
' ═══════════════════════════════════════════════════════════════════════════

package "Services" #F9F9F9 {

    class AuthService {
        -_db : AppDbContext
        -_config : IConfiguration
        +LoginAsync(username : string, password : string) : Task<LoginResult?>
        -GenerateToken(user : User) : string
    }

    class UserService {
        -_db : AppDbContext
        +GetAllAsync() : Task<List<UserDto>>
        +CreateAsync(req : CreateUserRequest) : Task<User>
        +UpdateAsync(id : int, req : UpdateUserRequest) : Task<User>
        +DeleteAsync(id : int) : Task
    }

    class TableService {
        -_db : AppDbContext
        +GetAllAsync() : Task<List<Table>>
        +GetAsync(id : int) : Task<Table>
        +SeatGuestsAsync(tableId : int, guestCount : int, waiterName : string?) : Task<Table>
        +ReserveAsync(tableId : int, guestName : string, time : string) : Task<Table>
        +RequestBillAsync(tableId : int) : Task<Table>
        +ClearTableAsync(tableId : int) : Task<Table>
    }

    class OrderService {
        -_db : AppDbContext
        -_eventBus : OrderEventBus
        +GetAllAsync() : Task<List<Order>>
        +GetAsync(id : string) : Task<Order>
        +GetActiveByTableAsync(tableNumber : int) : Task<Order?>
        +CreateAsync(tableNumber : int, items : List<OrderItem>, waiter : string) : Task<string>
        +PollEvents() : IReadOnlyList<OrderEvent>
    }

    class KitchenService {
        -_db : AppDbContext
        -_invoker : KitchenCommandInvoker
        -_eventBus : OrderEventBus
        +GetQueueAsync() : Task<List<Order>>
        +AdvanceStatusAsync(orderId : string) : Task<Order>
        +UndoLast() : string?
        +CancelOrderAsync(orderId : string) : Task<Order>
    }

    class MenuService {
        -_db : AppDbContext
        +GetAllAsync() : Task<List<MenuItem>>
        +GetCombos() : IReadOnlyList<IMenuComponent>
        +PreviewWithAddonsAsync(menuItemId : string, addonIds : IEnumerable<string>) : Task<(string, decimal)>
    }

    class BillingService {
        -_db : AppDbContext
        -_facade : BillingFacade
        +PreviewAsync(orderId : string, strategyName : string, tip : decimal, splitCount : int) : Task<BillResult>
        +CloseBillAsync(orderId : string, strategyName : string, tip : decimal, paymentMethod : string, splitCount : int) : Task<HistoryEntry>
        +GetHistoryAsync(from : DateTime?, to : DateTime?, tableNumber : int?) : Task<List<HistoryEntry>>
        +GetEndOfNightReportAsync() : Task<object>
    }

    class ReservationService {
        -_db : AppDbContext
        +GetAllAsync() : Task<List<Reservation>>
        +CreateAsync(dto : CreateReservationDto) : Task<Reservation>
        +UpdateStatusAsync(id : string, status : string) : Task<Reservation>
        +DeleteAsync(id : string) : Task
    }

}

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — ENTITIES
' ═══════════════════════════════════════════════════════════════════════════

Order "1" *-- "1..*" OrderItem : contains >
OrderItem "1" *-- "0..*" OrderAddon : has >
MenuItem "1" *-- "0..*" MenuAddon : has >

Order ..> OrderStatus : uses
Table ..> TableStatus : uses

Order "0..*" --> "1" Table : tableNumber >
Reservation "0..*" --> "1" Table : tableNumber >

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — DATA LAYER
' ═══════════════════════════════════════════════════════════════════════════

AppDbContext "1" *-- "0..*" Table : Tables
AppDbContext "1" *-- "0..*" Order : Orders
AppDbContext "1" *-- "0..*" MenuItem : MenuItems
AppDbContext "1" *-- "0..*" Reservation : Reservations
AppDbContext "1" *-- "0..*" HistoryEntry : HistoryEntries
AppDbContext "1" *-- "0..*" User : Users

DbSeeder ..> AppDbContext : parameter
DbSeeder ..> MealItemFactory : uses

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — COMMAND PATTERN
' ═══════════════════════════════════════════════════════════════════════════

PrepareOrderCommand ..|> ICommand
CancelOrderCommand ..|> ICommand
UpdateOrderStatusCommand ..|> ICommand

KitchenCommandInvoker "1" *-- "0..*" ICommand : _history stack

PrepareOrderCommand --> AppDbContext : uses
UpdateOrderStatusCommand --> AppDbContext : uses
CancelOrderCommand --> AppDbContext : uses
CancelOrderCommand ..> OrderHistoryLog : writes to

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — OBSERVER PATTERN
' ═══════════════════════════════════════════════════════════════════════════

KitchenObserver ..|> IOrderObserver
WaiterObserver ..|> IOrderObserver

OrderEventBus "1" o-- "0..*" IOrderObserver : _observers
OrderEventBus "1" *-- "0..*" OrderEvent : _pendingEvents

OrderEvent --> Order : references

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — STRATEGY PATTERN
' ═══════════════════════════════════════════════════════════════════════════

StandardPricingStrategy ..|> IPricingStrategy
HappyHourStrategy ..|> IPricingStrategy
LoyaltyDiscountStrategy ..|> IPricingStrategy
GroupDiscountStrategy ..|> IPricingStrategy

PricingStrategyFactory ..> IPricingStrategy : returns

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — STATE PATTERN
' ═══════════════════════════════════════════════════════════════════════════

FreeState ..|> ITableState
ReservedState ..|> ITableState
OccupiedState ..|> ITableState
AwaitingBillState ..|> ITableState
ClearedState ..|> ITableState

TableContext "1" *-- "1" ITableState : _state (current)
TableContext --> Table : manages

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — SINGLETON PATTERN
' ═══════════════════════════════════════════════════════════════════════════

OrderHistoryLog "1" *-- "0..*" HistoryEntry : _entries

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — ITERATOR PATTERN
' ═══════════════════════════════════════════════════════════════════════════

FilteredHistoryIterator ..|> IHistoryIterator
FilteredHistoryIterator ..> OrderHistoryLog : reads from

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — DECORATOR PATTERN
' ═══════════════════════════════════════════════════════════════════════════

BaseMealItem ..|> IMealComponent
AddonDecorator ..|> IMealComponent
AddonDecorator "1" *-- "1" IMealComponent : _inner (wraps)

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — FACADE PATTERN
' ═══════════════════════════════════════════════════════════════════════════

BillingFacade ..> Order : calculates from
BillingFacade ..> IPricingStrategy : applies
BillingFacade ..> BillResult : produces

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — FACTORY PATTERN
' ═══════════════════════════════════════════════════════════════════════════

StandardMealFactory --|> MealItemFactory
ComboMealFactory --|> MealItemFactory
MealItemFactory ..> MenuItem : <<creates>>

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — COMPOSITE PATTERN
' ═══════════════════════════════════════════════════════════════════════════

SingleMenuItem ..|> IMenuComponent
ComboMealGroup ..|> IMenuComponent
ComboMealGroup "1" *-- "0..*" IMenuComponent : _children
SingleMenuItem --> MenuItem : wraps

' ═══════════════════════════════════════════════════════════════════════════
' RELATIONSHIPS — SERVICES
' ═══════════════════════════════════════════════════════════════════════════

AuthService --> AppDbContext
UserService --> AppDbContext

TableService --> AppDbContext
TableService ..> TableContext : <<creates>>

OrderService --> AppDbContext
OrderService --> OrderEventBus

KitchenService --> AppDbContext
KitchenService --> KitchenCommandInvoker
KitchenService --> OrderEventBus
KitchenService ..> PrepareOrderCommand : <<creates>>
KitchenService ..> CancelOrderCommand : <<creates>>
KitchenService ..> UpdateOrderStatusCommand : <<creates>>

MenuService --> AppDbContext
MenuService ..> BaseMealItem : <<creates>>
MenuService ..> AddonDecorator : <<creates>>
MenuService ..> IMenuComponent : returns

BillingService --> AppDbContext
BillingService *-- BillingFacade : _facade
BillingService ..> PricingStrategyFactory : uses
BillingService ..> FilteredHistoryIterator : <<creates>>
BillingService ..> OrderHistoryLog : reads/writes
BillingService ..> TableContext : <<creates>>

ReservationService --> AppDbContext
ReservationService ..> TableContext : <<creates>>

@enduml
